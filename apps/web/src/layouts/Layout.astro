---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PlannerOverlay from '../components/planner/PlannerOverlay.svelte';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Bee Champs Hub",
  description = "Plánovací platforma pro MŠ a ZŠ — sport, vzdělávání, pobyty na jednom místě"
} = Astro.props;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Syne:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-bg-primary text-text-primary antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <PlannerOverlay client:load />
  </body>
</html>
