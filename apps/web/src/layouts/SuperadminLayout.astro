---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Superadmin | Bee Champs Hub" } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/superadmin", label: "Dashboard", icon: '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>' },
  { href: "/superadmin/logs", label: "Worker Logy", icon: '<path d="M13 12h8"/><path d="M13 18h8"/><path d="M13 6h8"/><path d="M3 12h1"/><path d="M3 18h1"/><path d="M3 6h1"/><path d="M8 12h1"/><path d="M8 18h1"/><path d="M8 6h1"/>' },
  { href: "/superadmin/d1", label: "D1 Konzole", icon: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>' },
  { href: "/superadmin/cache", label: "Cache Purge", icon: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>' },
];

function isActive(href: string): boolean {
  if (href === "/superadmin") return currentPath === "/superadmin" || currentPath === "/superadmin/";
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Syne:wght@600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-[#F0EDE8] text-text-dark antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar (desktop) -->
      <aside class="hidden lg:flex w-64 flex-col bg-[#0D1322] border-r border-white/[0.06] fixed inset-y-0 left-0 z-40">
        <!-- Logo -->
        <div class="flex items-center gap-2.5 px-5 py-5 border-b border-white/[0.06]">
          <div class="bg-amber-500 p-1.5 rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#0A0F1C]"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          </div>
          <div>
            <span class="text-sm font-bold font-heading">Bee Champs <span class="text-amber-400">Super</span></span>
          </div>
        </div>

        <!-- Navigace -->
        <nav class="flex-1 px-3 py-4 space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors",
                isActive(item.href)
                  ? "bg-amber-500/15 text-amber-400"
                  : "text-slate-400 hover:bg-white/5 hover:text-white"
              ]}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 shrink-0">
                <Fragment set:html={item.icon} />
              </svg>
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Footer -->
        <div class="px-3 py-4 border-t border-white/[0.06] space-y-1">
          <a href="/admin" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-white/5 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m15 18-6-6 6-6"/></svg>
            Zpět do adminu
          </a>
          <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-white/5 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Na web
          </a>
          <button
            id="sa-logout-btn"
            class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-slate-400 hover:text-red-400 hover:bg-red-400/10 transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
            Odhlásit se
          </button>
        </div>
      </aside>

      <!-- Mobile header -->
      <header class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-[#0D1322] border-b border-white/[0.06] h-14 flex items-center justify-between px-4">
        <a href="/superadmin" class="flex items-center gap-2">
          <div class="bg-amber-500 p-1.5 rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#0A0F1C]"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          </div>
          <span class="text-sm font-bold font-heading">Super</span>
        </a>
        <button id="sa-menu-btn" class="p-2 text-slate-400 hover:text-white">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
            <line x1="4" y1="6" x2="20" y2="6" /><line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="18" x2="20" y2="18" />
          </svg>
        </button>
      </header>

      <!-- Mobile nav overlay -->
      <div id="sa-nav-backdrop" class="fixed inset-0 z-[110] bg-black/50 hidden lg:hidden"></div>
      <aside id="sa-nav-panel" class="fixed top-0 right-0 bottom-0 z-[120] w-64 bg-[#0D1322] border-l border-white/[0.06] translate-x-full lg:hidden transition-transform duration-300">
        <div class="flex items-center justify-between px-4 py-4 border-b border-white/[0.06]">
          <span class="text-sm font-bold font-heading">Navigace</span>
          <button id="sa-nav-close" class="p-1 text-slate-400 hover:text-white">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
              <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
        <nav class="p-3 space-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors",
                isActive(item.href)
                  ? "bg-amber-500/15 text-amber-400"
                  : "text-slate-400 hover:bg-white/5 hover:text-white"
              ]}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 shrink-0">
                <Fragment set:html={item.icon} />
              </svg>
              {item.label}
            </a>
          ))}
        </nav>
      </aside>

      <!-- Main content -->
      <main class="flex-1 lg:ml-64 pt-14 lg:pt-0">
        <div class="p-4 sm:p-6 lg:p-8">
          <slot />
        </div>
      </main>
    </div>

    <script>
      function initSuperadminNav() {
        const btn = document.getElementById('sa-menu-btn')
        const panel = document.getElementById('sa-nav-panel')
        const backdrop = document.getElementById('sa-nav-backdrop')
        const closeBtn = document.getElementById('sa-nav-close')

        function open() {
          backdrop?.classList.remove('hidden')
          panel?.classList.remove('translate-x-full')
        }
        function close() {
          panel?.classList.add('translate-x-full')
          backdrop?.classList.add('hidden')
        }

        btn?.addEventListener('click', open)
        closeBtn?.addEventListener('click', close)
        backdrop?.addEventListener('click', close)
        panel?.querySelectorAll('a').forEach(a => a.addEventListener('click', close))

        // Logout — volame API pro smazani HttpOnly cookie
        const logoutBtn = document.getElementById('sa-logout-btn')
        logoutBtn?.addEventListener('click', async () => {
          try {
            await fetch('/api/superadmin/logout', {
              method: 'POST',
              credentials: 'include',
            })
          } catch {}
          window.location.href = '/superadmin/login'
        })
      }

      initSuperadminNav()
      document.addEventListener('astro:page-load', initSuperadminNav)
    </script>
  </body>
</html>
