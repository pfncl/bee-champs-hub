---
import { CalendarRange } from '@lucide/astro';
import { t } from '@i18n';
---

<section class="bg-bg-primary py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
    <!-- Hexagon ikona -->
    <div class="inline-flex bg-primary/10 p-4 rounded-2xl mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
      </svg>
    </div>

    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 font-heading">
      {t.cta.title}
    </h2>
    <p class="text-text-secondary text-lg mb-8 max-w-xl mx-auto">
      {t.cta.subtitle}
    </p>
    <a
      href="/planovac"
      class="bg-primary hover:bg-primary-hover text-bg-primary px-8 py-4 rounded-lg font-bold text-lg transition-all inline-flex items-center justify-center gap-3"
    >
      <CalendarRange class="w-5 h-5" />
      {t.common.openPlanner}
    </a>
  </div>
</section>
