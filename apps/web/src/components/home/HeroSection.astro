---
import { CalendarRange, CircleCheckBig } from '@lucide/astro';
import { t } from '@i18n';

interface Props {
  settings?: Record<string, string>;
}

const { settings = {} } = Astro.props;

// Statistiky z DB nastaveni, fallback na i18n
const stat1Value = settings.stat1_value ?? t.hero.stat1Value;
const stat1Label = settings.stat1_label ?? t.hero.stat1Label;
const stat2Value = settings.stat2_value ?? t.hero.stat2Value;
const stat2Label = settings.stat2_label ?? t.hero.stat2Label;
const stat3Value = settings.stat3_value ?? t.hero.stat3Value;
const stat3Label = settings.stat3_label ?? t.hero.stat3Label;
---

<section class="relative pt-32 pb-24 overflow-hidden bg-bg-primary text-white">
  <!-- Dekorativní bloby -->
  <div class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] rounded-full bg-primary/10 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-[-10%] left-[-5%] w-[400px] h-[400px] rounded-full bg-cat-projects/10 blur-[80px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Levý sloupec — text -->
      <div class="max-w-2xl fade-up">
        <h1 class="text-3xl sm:text-5xl lg:text-[3.5rem] font-heading font-extrabold mb-6 leading-[1.1] text-white">
          {t.hero.title} <span class="text-primary">{t.hero.titleHighlight}</span>
        </h1>

        <p class="text-xl text-white/80 mb-10 text-balance">
          {t.hero.subtitle}
        </p>

        <!-- CTA tlačítka -->
        <div class="flex flex-wrap gap-3 sm:gap-4">
          <a
            href="/planovac"
            class="px-6 py-3 sm:px-8 sm:py-4 bg-primary hover:bg-primary-hover text-bg-primary rounded-xl font-bold text-base sm:text-lg shadow-[0_0_30px_rgba(245,166,35,0.3)] hover:shadow-[0_0_40px_rgba(245,166,35,0.5)] transition-all duration-300 flex items-center gap-2"
          >
            <CalendarRange class="w-5 h-5" />
            {t.hero.openPlanner}
          </a>
          <a
            href="#kategorie"
            class="px-6 py-3 sm:px-8 sm:py-4 bg-white/10 hover:bg-white/20 text-white border border-white/20 rounded-xl font-bold text-base sm:text-lg transition-all duration-300"
          >
            {t.common.browsePrograms}
          </a>
        </div>

        <!-- Statistiky -->
        <div class="mt-12 flex gap-6 sm:gap-8">
          <div>
            <h4 class="text-3xl font-heading font-bold text-white mb-1">{stat1Value}</h4>
            <p class="text-white/60 text-sm">{stat1Label}</p>
          </div>
          <div>
            <h4 class="text-3xl font-heading font-bold text-white mb-1">{stat2Value}</h4>
            <p class="text-white/60 text-sm">{stat2Label}</p>
          </div>
          <div>
            <h4 class="text-3xl font-heading font-bold text-white mb-1">{stat3Value}</h4>
            <p class="text-white/60 text-sm">{stat3Label}</p>
          </div>
        </div>
      </div>

      <!-- Pravý sloupec — obrázek -->
      <div class="relative hidden lg:block fade-up" style="transition-delay: 0.2s;">
        <img
          src="/images/hero.avif"
          alt="Děti cvičící v tělocvičně"
          class="rounded-3xl shadow-2xl object-cover h-[600px] w-full border-4 border-white/10"
        />

        <!-- Plovoucí kartička -->
        <div class="absolute -bottom-6 -left-6 bg-white text-bg-primary p-6 rounded-2xl flex items-center gap-4 shadow-xl">
          <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600">
            <CircleCheckBig class="w-6 h-6" />
          </div>
          <div>
            <p class="font-bold font-heading">{t.hero.easyPlanning}</p>
            <p class="text-sm text-text-muted">{t.hero.saveTime}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
