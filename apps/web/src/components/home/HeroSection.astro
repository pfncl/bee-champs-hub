---
import { CalendarRange, CircleCheckBig } from '@lucide/astro';
---

<section class="relative pt-32 pb-24 overflow-hidden bg-bg-primary text-white">
  <!-- Dekorativní bloby -->
  <div class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] rounded-full bg-primary/10 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-[-10%] left-[-5%] w-[400px] h-[400px] rounded-full bg-cat-projects/10 blur-[80px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Levý sloupec — text -->
      <div class="max-w-2xl">
        <h1 class="text-5xl lg:text-7xl font-heading font-extrabold mb-6 leading-[1.1] text-white">
          Plánujte celý školní rok na <span class="text-primary">jednom místě</span>
        </h1>

        <p class="text-xl text-white/80 mb-10 text-balance">
          Inovativní nástroj pro MŠ a ZŠ. Vyberte si z desítek ověřených programů a sestavte si harmonogram na míru vašim žákům během pár minut.
        </p>

        <!-- CTA tlačítka -->
        <div class="flex flex-wrap gap-4">
          <a
            href="/planovac"
            class="px-8 py-4 bg-primary hover:bg-primary-hover text-bg-primary rounded-xl font-bold text-lg shadow-[0_0_30px_rgba(245,166,35,0.3)] hover:shadow-[0_0_40px_rgba(245,166,35,0.5)] hover:-translate-y-1 transition-all duration-300 flex items-center gap-2"
          >
            <CalendarRange class="w-5 h-5" />
            Otevřít plánovač
          </a>
          <a
            href="#kategorie"
            class="px-8 py-4 bg-white/10 hover:bg-white/20 text-white border border-white/20 rounded-xl font-bold text-lg transition-all duration-300"
          >
            Prohlédnout programy
          </a>
        </div>

        <!-- Statistiky -->
        <div class="mt-12 flex gap-8">
          <div>
            <h4 class="text-3xl font-heading font-bold text-white mb-1">50+</h4>
            <p class="text-white/60 text-sm">Ověřených programů</p>
          </div>
          <div>
            <h4 class="text-3xl font-heading font-bold text-white mb-1">100+</h4>
            <p class="text-white/60 text-sm">Spokojených škol</p>
          </div>
          <div>
            <h4 class="text-3xl font-heading font-bold text-white mb-1">10k+</h4>
            <p class="text-white/60 text-sm">Dětí v programech</p>
          </div>
        </div>
      </div>

      <!-- Pravý sloupec — obrázek -->
      <div class="relative hidden lg:block">
        <img
          src="/images/hero.avif"
          alt="Děti cvičící v tělocvičně"
          class="rounded-3xl shadow-2xl object-cover h-[600px] w-full border-4 border-white/10"
        />

        <!-- Plovoucí kartička -->
        <div class="absolute -bottom-6 -left-6 bg-white text-bg-primary p-6 rounded-2xl flex items-center gap-4 shadow-xl">
          <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600">
            <CircleCheckBig class="w-6 h-6" />
          </div>
          <div>
            <p class="font-bold font-heading">Snadné plánování</p>
            <p class="text-sm text-text-muted">Ušetřete hodiny času</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
