---
import { navigation } from '@data/siteData';
import { CalendarRange } from '@lucide/astro';
import PlannerBadge from './planner/PlannerBadge.svelte';
import { t } from '@i18n';

// Ikony pro navigaci v mobilnim panelu
const navIcons: Record<string, string> = {
  '/sport': '<path d="M6.5 6.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/><path d="m2 21 1.9-5.7a8.5 8.5 0 0 1 0-7.6"/><path d="m7 21-1.9-5.7"/><path d="M22 21H2"/><path d="m16 8-4 4"/><path d="m20 4-8 8"/>',
  '/vzdelavani': '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  '/projektove-dny': '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>',
  '/akce': '<path d="M4 22h16a2 2 0 0 0 2-2V4c0-1.1-.9-2-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>',
};
---

<header class="fixed flex items-center justify-center w-full z-50 bg-bg-primary/97 backdrop-blur-sm border-b border-border-primary h-[68px]">
  <nav class="max-w-7xl w-full px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <div class="bg-primary p-2 rounded-xl transition-transform duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-bg-primary fill-current"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
        </div>
        <span class="text-xl font-bold font-heading text-white hidden sm:inline">
          Bee Champs <span class="text-primary">Hub</span>
        </span>
      </a>

      <!-- Desktop navigace -->
      <div class="hidden md:flex md:items-center md:gap-8">
        {navigation.map((item) => (
          <a
            href={item.href}
            class="text-text-secondary hover:text-primary transition-colors font-medium text-base py-2"
          >
            {item.name}
          </a>
        ))}
        <a
          href="/planovac"
          class="bg-bg-tertiary hover:bg-white/15 text-white rounded-lg font-semibold transition-all duration-200 inline-flex items-center justify-center gap-2 px-5 py-2"
        >
          <CalendarRange class="w-4 h-4 text-white/70" />
          {t.planner.title}
          <PlannerBadge client:load />
        </a>
      </div>

      <!-- Mobilni: planovac + hamburger -->
      <div class="flex items-center gap-2 md:hidden">
        <a
          href="/planovac"
          class="bg-primary hover:bg-primary-hover text-bg-primary rounded-lg font-semibold transition-all duration-200 inline-flex items-center justify-center gap-1.5 px-3 py-2 text-sm"
        >
          <CalendarRange class="w-4 h-4" />
          <span class="hidden xs:inline">{t.nav.plannerShort}</span>
          <PlannerBadge client:load />
        </a>
        <button
          id="hamburger-btn"
          class="flex items-center justify-center p-2 text-text-secondary hover:text-white transition-colors rounded-lg"
          aria-label="Menu"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
            <line x1="4" y1="6" x2="20" y2="6" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="18" x2="20" y2="18" />
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- Mobilni backdrop -->
<div class="fixed inset-0 z-[110] bg-black/50 hidden transition-opacity" id="mobile-backdrop"></div>

<!-- Mobilni side panel -->
<aside
  class="fixed top-0 right-0 bottom-0 z-[120] w-3/4 max-w-xs bg-bg-primary border-l border-border-primary overflow-y-auto translate-x-full transition-transform duration-300"
  id="mobile-nav"
>
  <!-- Hlavicka panelu -->
  <div class="flex items-center justify-between border-b border-border-primary px-4 py-4">
    <a href="/" class="flex items-center gap-2">
      <div class="bg-primary p-1.5 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-bg-primary fill-current"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
      </div>
      <span class="text-sm font-bold font-heading text-white">Bee Champs <span class="text-primary">Hub</span></span>
    </a>
    <button id="mobile-close-btn" class="rounded-lg p-1.5 text-text-secondary hover:text-white transition-colors" aria-label="Zavřít">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Navigacni polozky -->
  <nav class="space-y-1 p-3">
    {navigation.map((item) => (
      <a
        href={item.href}
        class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-text-secondary transition-colors hover:bg-bg-tertiary hover:text-white"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 shrink-0">
          <Fragment set:html={navIcons[item.href] ?? ''} />
        </svg>
        <span>{item.name}</span>
      </a>
    ))}

    <div class="border-t border-border-primary mt-2 pt-2">
      <a
        href="/planovac"
        class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-primary transition-colors hover:bg-primary/10"
      >
        <CalendarRange class="w-5 h-5" />
        <span>{t.planner.title}</span>
        <PlannerBadge client:load />
      </a>
    </div>
  </nav>
</aside>

<script>
  function initMobileNav() {
    const btn = document.getElementById('hamburger-btn')
    const panel = document.getElementById('mobile-nav')
    const backdrop = document.getElementById('mobile-backdrop')
    const closeBtn = document.getElementById('mobile-close-btn')

    if (!btn || !panel) return

    function openNav() {
      backdrop?.classList.remove('hidden')
      panel?.classList.remove('translate-x-full')
    }
    function closeNav() {
      panel?.classList.add('translate-x-full')
      backdrop?.classList.add('hidden')
    }

    btn.addEventListener('click', openNav)
    closeBtn?.addEventListener('click', closeNav)
    backdrop?.addEventListener('click', closeNav)
    panel.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav))
  }

  // Podporuje i stranky bez View Transitions
  initMobileNav()
  document.addEventListener('astro:page-load', initMobileNav)
</script>
