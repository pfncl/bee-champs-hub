---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminSettings from '../../components/admin/AdminSettings.svelte';
import { apiFetchSSR } from '../../lib/api-server';

const cookie = Astro.request.headers.get("cookie");
const token = cookie?.match(/admin_token=([^;]+)/)?.[1] ?? "";

let settings: Record<string, string> = {}
try {
  settings = await apiFetchSSR<Record<string, string>>("/admin/settings", `admin_token=${token}`)
} catch {}
---

<AdminLayout title="Nastavení | Admin">
  <AdminSettings client:load initialSettings={settings} adminToken={token} />
</AdminLayout>
