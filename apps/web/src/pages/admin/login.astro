---
import '../../styles/global.css';
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Syne:wght@600;700;800&display=swap" rel="stylesheet" />
    <title>Přihlášení | Admin | Bee Champs Hub</title>
  </head>
  <body class="bg-bg-primary antialiased">
    <div class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="inline-flex bg-primary p-3 rounded-2xl mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-bg-primary fill-current"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
        </div>
        <h1 class="text-2xl font-bold text-white font-heading">Bee Champs <span class="text-primary">Admin</span></h1>
        <p class="text-text-secondary text-sm mt-1">Zadejte přístupový token</p>
      </div>

      <!-- Formulář -->
      <form id="login-form" class="bg-bg-secondary rounded-xl p-6 border border-border-primary">
        <div class="mb-4">
          <label for="token" class="block text-sm font-medium text-text-secondary mb-2">Admin token</label>
          <input
            id="token"
            name="token"
            type="password"
            required
            placeholder="Zadejte token..."
            class="w-full px-4 py-3 rounded-lg bg-bg-primary border border-border-primary text-white placeholder-text-muted focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
          />
        </div>
        <div id="error-msg" class="hidden mb-4 text-sm text-cat-events bg-cat-events/10 border border-cat-events/20 rounded-lg px-4 py-2"></div>
        <button
          type="submit"
          class="w-full bg-primary hover:bg-primary-hover text-bg-primary font-bold py-3 rounded-lg transition-colors"
        >
          Přihlásit se
        </button>
      </form>

      <div class="text-center mt-6">
        <a href="/" class="text-sm text-text-secondary hover:text-primary transition-colors">
          &larr; Zpět na web
        </a>
      </div>
    </div>
    </div>

    <script>
      const form = document.getElementById('login-form')
      const errorMsg = document.getElementById('error-msg')

      form?.addEventListener('submit', async (e) => {
        e.preventDefault()
        errorMsg?.classList.add('hidden')

        const token = new FormData(form).get('token')

        try {
          const res = await fetch('/api/admin/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ token }),
          })

          if (res.ok) {
            document.cookie = `admin_token=${token}; path=/; max-age=${30 * 24 * 60 * 60}; SameSite=Lax; Secure`
            window.location.href = '/admin'
          } else {
            errorMsg.textContent = 'Neplatný token'
            errorMsg?.classList.remove('hidden')
          }
        } catch {
          errorMsg.textContent = 'Chyba připojení k serveru'
          errorMsg?.classList.remove('hidden')
        }
      })
    </script>
  </body>
</html>
